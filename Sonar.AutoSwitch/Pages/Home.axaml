<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Sonar.AutoSwitch.ViewModels"
             xmlns:ui="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             xmlns:services="clr-namespace:Sonar.AutoSwitch.Services"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Sonar.AutoSwitch.Pages.Home"
             x:CompileBindings="True"
             x:DataType="viewModels:HomeViewModel">
    <UserControl.Styles>
        <!-- ExpanderHeader toggle button must carry the profile name for screen readers. -->
        <Style Selector="Expander /template/ ToggleButton#ExpanderHeader">
            <Setter Property="AutomationProperties.Name"
                    Value="{Binding $parent[Expander].(AutomationProperties.Name)}" />
        </Style>
    </UserControl.Styles>
    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="Auto Switch Profiles" Margin="0,0,0,8"
                   Theme="{StaticResource SubtitleTextBlockStyle}" />
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,4">
            <TextBlock Text="Active config: " />
            <TextBlock Text="{Binding ActiveProfile.Name}" FontWeight="Bold" />
        </StackPanel>
        <TextBlock DockPanel.Dock="Top" Text="Default config: " Margin="0,0,0,4" />
        <ComboBox DockPanel.Dock="Top" SelectedItem="{Binding DefaultSonarGamingConfiguration}"
                  PlaceholderText="Default game configuration" Margin="0,0,0,12"
                  ItemsSource="{Binding Path=AvailableGamingConfigurations, Source={x:Static services:SteelSeriesSonarService.Instance}}">
            <ComboBox.ItemTemplate>
                <DataTemplate DataType="services:SonarGamingConfiguration">
                    <TextBlock Text="{Binding Name}" />
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBox DockPanel.Dock="Top"
                 Text="{Binding SearchText, Mode=TwoWay}"
                 Watermark="Search profiles..."
                 Margin="0,0,0,4"
                 AutomationProperties.Name="Search profiles" />

        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top"
                    Margin="0,0,0,8" Spacing="4">
            <TextBlock Text="Sort:" VerticalAlignment="Center" Opacity="0.7" />
            <Button Command="{Binding CycleSort}"
                    ToolTip.Tip="{Binding SortModeTooltip}"
                    AutomationProperties.Name="Cycle sort order"
                    MinWidth="36"
                    Content="{Binding SortModeLabel}" />
        </StackPanel>

        <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding FilteredProfiles}"
                      HorizontalAlignment="Stretch">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="viewModels:AutoSwitchProfileViewModel">
                    <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Stretch"
                              Margin="0,1"
                              AutomationProperties.Name="{Binding DisplayName}">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding DisplayName}" />
                                <TextBlock Text="⚠" IsVisible="{Binding IsIncomplete}"
                                           Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                           FontSize="11" VerticalAlignment="Center"
                                           ToolTip.Tip="Game exe or Sonar config not set" />
                            </StackPanel>
                        </Expander.Header>

                        <StackPanel Margin="8,8,0,4" Spacing="5">

                            <ComboBox PlaceholderText="Fill from recent app..."
                                      SelectedItem="{Binding SelectedRecentWindow, Mode=OneWayToSource}"
                                      ItemsSource="{x:Static services:RecentWindowsService.RecentWindows}"
                                      AutomationProperties.Name="Pick recent app"
                                      HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:CompileBindings="False" DataType="services:RecentWindowInfo">
                                        <TextBlock Text="{Binding Display}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Text="Game exe:" FontSize="11" Opacity="0.65" />
                            <AutoCompleteBox Text="{Binding ExeName}"
                                             Watermark="e.g. Overwatch"
                                             FilterMode="Contains" MinimumPrefixLength="1"
                                             MaxDropDownHeight="200"
                                             ItemsSource="{x:Static viewModels:HomeViewModel.ProcessNames}"
                                             AutomationProperties.Name="Game executable name" />
                            <TextBlock Text="{Binding ExeRunningHint}"
                                       IsVisible="{Binding HasExeRunningHint}"
                                       Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                                       FontSize="11" Margin="2,0,0,0" />

                            <TextBlock Text="Sonar config:" FontSize="11" Opacity="0.65" Margin="0,4,0,0" />
                            <AutoCompleteBox Watermark="Search..."
                                             FilterMode="Contains" MinimumPrefixLength="1"
                                             MaxDropDownHeight="300"
                                             SelectedItem="{Binding SonarGamingConfiguration}"
                                             ItemsSource="{Binding Path=AvailableGamingConfigurations, Source={x:Static services:SteelSeriesSonarService.Instance}}"
                                             AutomationProperties.Name="Sonar gaming config">
                                <AutoCompleteBox.ItemTemplate>
                                    <DataTemplate x:CompileBindings="False" DataType="services:SonarGamingConfiguration">
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </AutoCompleteBox.ItemTemplate>
                            </AutoCompleteBox>
                            <TextBlock Text="{Binding SonarMatchHint}"
                                       IsVisible="{Binding HasSonarMatchHint}"
                                       FontSize="11" Opacity="0.65" Margin="2,0,0,0" />

                            <Expander Header="Advanced"
                                      IsExpanded="{Binding IsAdvancedExpanded, Mode=TwoWay}"
                                      HorizontalContentAlignment="Stretch"
                                      Margin="0,4,0,0"
                                      AutomationProperties.Name="Advanced matching options">
                                <StackPanel Spacing="4" Margin="0,4,0,0">
                                    <TextBlock Text="Window title:" FontSize="11" Opacity="0.65" />
                                    <TextBox Text="{Binding Title}"
                                             Watermark="e.g. Valorant"
                                             AutomationProperties.Name="Window title" />
                                </StackPanel>
                            </Expander>

                            <Grid ColumnDefinitions="*,Auto" Margin="0,6,0,0">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding CreatedAtLabel}"
                                           IsVisible="{Binding HasCreatedAt}"
                                           Opacity="0.4" FontSize="10"
                                           VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal"
                                            HorizontalAlignment="Right" Spacing="8">
                                    <Button IsVisible="{Binding !IsConfirmingDelete}"
                                            Command="{Binding StartDelete}"
                                            ToolTip.Tip="Delete this profile"
                                            AutomationProperties.Name="Delete profile">
                                        <ui:SymbolIcon Symbol="Delete" />
                                    </Button>
                                    <StackPanel IsVisible="{Binding IsConfirmingDelete}"
                                                Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Delete this profile?" VerticalAlignment="Center" Opacity="0.8" />
                                        <Button Command="{Binding ConfirmDelete}"
                                                Foreground="{DynamicResource SystemFillColorCriticalBrush}">Yes, delete</Button>
                                        <Button Command="{Binding CancelDelete}">Cancel</Button>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                        </StackPanel>
                    </Expander>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </DockPanel>
</UserControl>
