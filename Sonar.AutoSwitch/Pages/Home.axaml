<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Sonar.AutoSwitch.ViewModels"
             xmlns:ui="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             xmlns:services="clr-namespace:Sonar.AutoSwitch.Services"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Sonar.AutoSwitch.Pages.Home"
             x:CompileBindings="True"
             x:DataType="viewModels:HomeViewModel">
    <UserControl.Styles>
        <Style Selector="Expander /template/ ToggleButton#ExpanderHeader">
            <Setter Property="AutomationProperties.Name"
                    Value="{Binding $parent[Expander].(AutomationProperties.Name)}" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="12,0,10,0" />
        </Style>
    </UserControl.Styles>
    <DockPanel>

        <!-- Hero header with gradient background -->
        <Border DockPanel.Dock="Top"
                AutomationProperties.Name="Hero section"
                Padding="12,10,12,10">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#4D0078D4" Offset="0" />
                    <GradientStop Color="#140078D4" Offset="0.38" />
                    <GradientStop Color="#000078D4" Offset="0.66" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="#26FFFFFF" />
            </Border.BorderBrush>
            <Border.BorderThickness>0,0,0,1</Border.BorderThickness>

            <Grid ColumnDefinitions="*,Auto">
                <!-- Left column: status info -->
                <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Text="ACTIVE NOW"
                               FontSize="9" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentFillColorDefaultBrush}" />
                    <TextBlock Text="{Binding ActiveProfile.Name}"
                               FontSize="20" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               AutomationProperties.Name="Active config name" />
                    <!-- Status pill -->
                    <Border CornerRadius="9999"
                            Background="#20FFFFFF"
                            BorderBrush="#30FFFFFF"
                            BorderThickness="1"
                            Padding="8,3"
                            HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Ellipse Width="7" Height="7"
                                     Fill="{Binding SonarStatusBrush}"
                                     ToolTip.Tip="{Binding SonarStatusTooltip}"
                                     AutomationProperties.Name="Sonar connection status"
                                     VerticalAlignment="Center" />
                            <TextBlock Text="{Binding SonarStatusLabel}"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right column: EQ bars + settings gear stacked -->
                <Grid Grid.Column="1" RowDefinitions="Auto,*">
                    <!-- Settings button top-right -->
                    <Button Grid.Row="0"
                            Click="OpenSettings_Click"
                            ToolTip.Tip="Settings"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            AutomationProperties.Name="Open settings">
                        <ui:SymbolIcon Symbol="Settings" />
                    </Button>

                    <!-- Animated EQ bars, bottom-aligned -->
                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                Spacing="3"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Margin="0,4,0,0">
                        <Rectangle Width="4" RadiusX="2" RadiusY="2"
                                   Height="{Binding EqBar1}"
                                   VerticalAlignment="Bottom">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                    <GradientStop Color="#9999EBFF" Offset="0" />
                                    <GradientStop Color="#9960CDFF" Offset="1" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Rectangle Width="4" RadiusX="2" RadiusY="2"
                                   Height="{Binding EqBar2}"
                                   VerticalAlignment="Bottom">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                    <GradientStop Color="#9999EBFF" Offset="0" />
                                    <GradientStop Color="#9960CDFF" Offset="1" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Rectangle Width="4" RadiusX="2" RadiusY="2"
                                   Height="{Binding EqBar3}"
                                   VerticalAlignment="Bottom">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                    <GradientStop Color="#9999EBFF" Offset="0" />
                                    <GradientStop Color="#9960CDFF" Offset="1" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Rectangle Width="4" RadiusX="2" RadiusY="2"
                                   Height="{Binding EqBar4}"
                                   VerticalAlignment="Bottom">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                    <GradientStop Color="#9999EBFF" Offset="0" />
                                    <GradientStop Color="#9960CDFF" Offset="1" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Rectangle Width="4" RadiusX="2" RadiusY="2"
                                   Height="{Binding EqBar5}"
                                   VerticalAlignment="Bottom">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                    <GradientStop Color="#9999EBFF" Offset="0" />
                                    <GradientStop Color="#9960CDFF" Offset="1" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Rectangle Width="4" RadiusX="2" RadiusY="2"
                                   Height="{Binding EqBar6}"
                                   VerticalAlignment="Bottom">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                    <GradientStop Color="#9999EBFF" Offset="0" />
                                    <GradientStop Color="#9960CDFF" Offset="1" />
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Default config with label -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*" Margin="12,8,12,0">
            <TextBlock Grid.Column="0" Text="Default config:"
                       VerticalAlignment="Center" Opacity="0.7" Margin="0,0,8,0" />
            <ComboBox Grid.Column="1"
                      SelectedItem="{Binding DefaultSonarGamingConfiguration}"
                      PlaceholderText="None"
                      ItemsSource="{Binding Path=AvailableGamingConfigurations, Source={x:Static services:SteelSeriesSonarService.Instance}}">
                <ComboBox.ItemTemplate>
                    <DataTemplate DataType="services:SonarGamingConfiguration">
                        <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </Grid>

        <!-- PROFILES section label + persistent search box -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="12,8,12,4">
            <TextBlock Grid.Column="0"
                       Text="PROFILES"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       VerticalAlignment="Center" />
            <TextBox Grid.Column="1"
                     Width="140"
                     Text="{Binding SearchText, Mode=TwoWay}"
                     Watermark="Search..."
                     AutomationProperties.Name="Search profiles" />
        </Grid>

        <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding FilteredProfiles}"
                      HorizontalAlignment="Stretch">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="viewModels:AutoSwitchProfileViewModel">
                    <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Stretch"
                              Margin="0,2"
                              AutomationProperties.Name="{Binding DisplayName}">
                        <Expander.Header>
                            <!-- Grid: Col0=active dot, Col1=name+warning, Col2=preset badge -->
                            <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                                <!-- Active dot -->
                                <Ellipse Grid.Column="0"
                                         Width="7" Height="7"
                                         Fill="{DynamicResource SystemFillColorSuccessBrush}"
                                         IsVisible="{Binding IsActive}"
                                         Margin="0,0,6,0"
                                         VerticalAlignment="Center"
                                         AutomationProperties.Name="Active profile dot"
                                         ToolTip.Tip="Currently switching" />
                                <!-- Profile name + incomplete warning -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                                    <TextBlock Text="⚠" IsVisible="{Binding IsIncomplete}"
                                               Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                               FontSize="11" VerticalAlignment="Center"
                                               ToolTip.Tip="Game exe or Sonar config not set" />
                                </StackPanel>
                                <!-- Preset badge -->
                                <Border Grid.Column="2"
                                        IsVisible="{Binding HasSonarConfig}"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="6,1"
                                        Margin="6,0,0,0"
                                        VerticalAlignment="Center"
                                        AutomationProperties.Name="Sonar config badge">
                                    <TextBlock Text="{Binding SonarGamingConfiguration.Name}"
                                               FontSize="10"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </Border>
                            </Grid>
                        </Expander.Header>

                        <StackPanel Margin="8,8,0,4" Spacing="6">

                            <ComboBox PlaceholderText="Fill from recent app..."
                                      SelectedItem="{Binding SelectedRecentWindow, Mode=OneWayToSource}"
                                      ItemsSource="{x:Static services:RecentWindowsService.RecentWindows}"
                                      AutomationProperties.Name="Pick recent app"
                                      HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:CompileBindings="False" DataType="services:RecentWindowInfo">
                                        <TextBlock Text="{Binding Display}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Text="Game exe:" FontSize="11" Opacity="0.65" />
                            <Grid ColumnDefinitions="*,Auto">
                                <AutoCompleteBox Grid.Column="0"
                                                 Text="{Binding ExeName}"
                                                 Watermark="e.g. Overwatch"
                                                 FilterMode="Contains" MinimumPrefixLength="1"
                                                 MaxDropDownHeight="200"
                                                 ItemsSource="{x:Static viewModels:HomeViewModel.ProcessNames}"
                                                 AutomationProperties.Name="Game executable name" />
                                <Button Grid.Column="1"
                                        Click="BrowseExe_Click"
                                        ToolTip.Tip="Browse for exe file"
                                        AutomationProperties.Name="Browse for exe"
                                        Margin="4,0,0,0"
                                        VerticalAlignment="Center">
                                    <ui:SymbolIcon Symbol="Folder" />
                                </Button>
                            </Grid>
                            <TextBlock Text="{Binding ExeRunningHint}"
                                       IsVisible="{Binding HasExeRunningHint}"
                                       Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                                       FontSize="11" Margin="2,0,0,0" />

                            <TextBlock Text="Sonar config:" FontSize="11" Opacity="0.65" Margin="0,4,0,0" />
                            <AutoCompleteBox Watermark="Search..."
                                             FilterMode="Contains" MinimumPrefixLength="1"
                                             MaxDropDownHeight="300"
                                             SelectedItem="{Binding SonarGamingConfiguration}"
                                             ItemsSource="{Binding Path=AvailableGamingConfigurations, Source={x:Static services:SteelSeriesSonarService.Instance}}"
                                             AutomationProperties.Name="Sonar gaming config">
                                <AutoCompleteBox.ItemTemplate>
                                    <DataTemplate x:CompileBindings="False" DataType="services:SonarGamingConfiguration">
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </AutoCompleteBox.ItemTemplate>
                            </AutoCompleteBox>
                            <Border IsVisible="{Binding HasSonarMatchHint}"
                                    Background="#80393D1B"
                                    CornerRadius="9999"
                                    Padding="8,1"
                                    HorizontalAlignment="Left"
                                    Margin="0,1,0,0"
                                    AutomationProperties.Name="Auto-match hint">
                                <TextBlock Text="{Binding SonarMatchHint}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SystemFillColorSuccessBrush}" />
                            </Border>

                            <Expander Header="Advanced"
                                      IsExpanded="{Binding IsAdvancedExpanded, Mode=TwoWay}"
                                      HorizontalContentAlignment="Stretch"
                                      Margin="0,4,0,0"
                                      AutomationProperties.Name="Advanced matching options">
                                <StackPanel Spacing="4" Margin="0,4,0,0">
                                    <TextBlock Text="Window title:" FontSize="11" Opacity="0.65" />
                                    <TextBox Text="{Binding Title}"
                                             Watermark="e.g. Valorant"
                                             AutomationProperties.Name="Window title" />
                                </StackPanel>
                            </Expander>

                            <Grid ColumnDefinitions="*,Auto" Margin="0,6,0,0">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding CreatedAtLabel}"
                                           IsVisible="{Binding HasCreatedAt}"
                                           Opacity="0.4" FontSize="10"
                                           VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal"
                                            HorizontalAlignment="Right" Spacing="8">
                                    <Button IsVisible="{Binding !IsConfirmingDelete}"
                                            Command="{Binding StartDelete}"
                                            ToolTip.Tip="Delete this profile"
                                            AutomationProperties.Name="Delete profile">
                                        <ui:SymbolIcon Symbol="Delete" />
                                    </Button>
                                    <StackPanel IsVisible="{Binding IsConfirmingDelete}"
                                                Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Delete this profile?" VerticalAlignment="Center" Opacity="0.8" />
                                        <Button Command="{Binding ConfirmDelete}"
                                                Foreground="{DynamicResource SystemFillColorCriticalBrush}">Yes, delete</Button>
                                        <Button Command="{Binding CancelDelete}">Cancel</Button>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                        </StackPanel>
                    </Expander>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button DockPanel.Dock="Top"
                Click="AddProfile_Click"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Margin="0,8,0,0"
                AutomationProperties.Name="Add profile">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <ui:SymbolIcon Symbol="Add" />
                <TextBlock Text="Add profile" />
            </StackPanel>
        </Button>

    </DockPanel>
</UserControl>
