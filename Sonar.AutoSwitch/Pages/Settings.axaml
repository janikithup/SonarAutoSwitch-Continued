<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             xmlns:viewModels="clr-namespace:Sonar.AutoSwitch.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Sonar.AutoSwitch.Pages.Settings"
             x:CompileBindings="True"
             x:DataType="viewModels:SettingsViewModel">

    <StackPanel Spacing="6">

        <!-- Header: Settings title + Back button -->
        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
            <TextBlock Grid.Column="0" Text="Settings"
                       Theme="{StaticResource SubtitleTextBlockStyle}"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1" Click="Back_Click"
                    AutomationProperties.Name="Back to profiles">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <ui:SymbolIcon Symbol="Back" />
                    <TextBlock Text="Back" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Compact toggle rows -->
        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="4" Padding="12,10">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="Enabled" FontWeight="SemiBold" />
                    <TextBlock Text="Enable or disable Sonar Auto Switch"
                               FontSize="11" Opacity="0.65" />
                </StackPanel>
                <ToggleSwitch Grid.Column="1" IsChecked="{Binding Enabled}"
                              VerticalAlignment="Center"
                              AutomationProperties.Name="Enabled" />
            </Grid>
        </Border>

        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="4" Padding="12,10">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="Start at startup" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding StartupDescription}"
                               FontSize="11" Opacity="0.65" />
                </StackPanel>
                <ToggleSwitch Grid.Column="1" IsChecked="{Binding StartAtStartup}"
                              VerticalAlignment="Center"
                              AutomationProperties.Name="StartAtStartup" />
            </Grid>
        </Border>

        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="4" Padding="12,10">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="Use GitHub profiles" FontWeight="SemiBold" />
                    <TextBlock Text="Use profiles set by users in GitHub"
                               FontSize="11" Opacity="0.65" />
                </StackPanel>
                <ToggleSwitch Grid.Column="1" IsChecked="{Binding UseGithubConfigs}"
                              VerticalAlignment="Center"
                              AutomationProperties.Name="UseGithubConfigs" />
            </Grid>
        </Border>

        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="4" Padding="12,10">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="Close to tray" FontWeight="SemiBold" />
                    <TextBlock Text="Closing the window hides to tray instead of exiting"
                               FontSize="11" Opacity="0.65" />
                </StackPanel>
                <ToggleSwitch Grid.Column="1" IsChecked="{Binding CloseToTray}"
                              VerticalAlignment="Center"
                              AutomationProperties.Name="CloseToTray" />
            </Grid>
        </Border>

        <Rectangle Height="1" Fill="{DynamicResource CardStrokeColorDefaultBrush}" Margin="0,6,0,2" />

        <!-- Version + update -->
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,6">
            <TextBlock x:Name="VersionLabel" VerticalAlignment="Center" />
            <Button Content="Copy" Click="CopyVersion_Click" Padding="8,3" FontSize="12"
                    AutomationProperties.Name="Copy version" />
            <Button Content="Check for updates" Click="CheckUpdates_Click" Padding="8,3" FontSize="12"
                    AutomationProperties.Name="Check for updates" />
            <TextBlock x:Name="UpdateStatus" VerticalAlignment="Center" Opacity="0.6" FontSize="12" />
        </StackPanel>

        <!-- Troubleshooting -->
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,6">
            <Button Content="Open log file" Click="OpenLog_Click"
                    AutomationProperties.Name="Open log file" />
            <Button Content="Open config folder" Click="OpenFolder_Click"
                    AutomationProperties.Name="Open config folder" />
        </StackPanel>

        <!-- Reset -->
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="ResetButton" Content="Reset to defaults" Click="Reset_Click"
                    Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                    AutomationProperties.Name="Reset to defaults" />
        </StackPanel>
        <StackPanel x:Name="ResetConfirmPanel" IsVisible="False" Orientation="Horizontal"
                    Spacing="8" Margin="0,4,0,0">
            <TextBlock Text="Delete all profiles and settings?" VerticalAlignment="Center" Opacity="0.8" />
            <Button Content="Yes, reset everything" Click="ResetConfirm_Click"
                    Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                    AutomationProperties.Name="Confirm reset" />
            <Button Content="Cancel" Click="ResetCancel_Click"
                    AutomationProperties.Name="Cancel reset" />
        </StackPanel>

        <Rectangle Height="1" Fill="{DynamicResource CardStrokeColorDefaultBrush}" Margin="0,6,0,2" />
        <HyperlinkButton Content="github.com/janikithup/SonarAutoSwitch-Continued"
                         NavigateUri="https://github.com/janikithup/SonarAutoSwitch-Continued" />

    </StackPanel>
</UserControl>
