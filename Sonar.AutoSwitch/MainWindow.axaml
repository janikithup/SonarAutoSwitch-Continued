<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
        mc:Ignorable="d" Width="600" Height="500"
        x:Class="Sonar.AutoSwitch.MainWindow"
        TransparencyLevelHint="Mica"
        Icon="/Assets/icon.ico"
        Title="Sonar Auto Switch">
    <ui:NavigationView SelectionChanged="NavigationView_OnSelectionChanged" PaneDisplayMode="LeftCompact"
                       OpenPaneLength="180">
        <ui:NavigationView.MenuItems>
            <ui:NavigationViewItem Content="Home" IsSelected="True" Tag="Home" IconSource="Home" />
            <ui:NavigationViewItem Content="About" Tag="About" IconSource="Help" />
        </ui:NavigationView.MenuItems>
        <ui:NavigationView.PaneFooter>
            <Button Click="AddProfile_Click"
                    HorizontalAlignment="Left"
                    Margin="4,0,4,8"
                    ToolTip.Tip="Add profile"
                    AutomationProperties.Name="Add profile">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <ui:SymbolIcon Symbol="Add" />
                    <TextBlock Text="Add profile" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </ui:NavigationView.PaneFooter>
        <ScrollViewer Padding="8">
            <ui:Frame Name="FrameView" />
        </ScrollViewer>
    </ui:NavigationView>
</Window>
